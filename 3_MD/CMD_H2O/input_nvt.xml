<simulation verbosity='high'>
  <output prefix='simulation'>
      <properties filename='out' stride='1'> [step, time{picosecond}, potential{kelvin}, kinetic_cv{kelvin}, conserved{kelvin}, temperature{kelvin}, volume{angstrom3}, density{g/cm3}] </properties>
    <trajectory filename='pos' stride='1' format='xyz' cell_units='angstrom'> positions{angstrom} </trajectory>
    <trajectory filename='for' stride='1' format='xyz' cell_units='angstrom'> forces </trajectory>
    <checkpoint stride='10'/>
  </output>
  <total_steps>300000</total_steps>
  <prng>
    <seed>12345</seed>
  </prng>
  <ffsocket name='dmff' mode='unix'>
    <address> unix_dmff </address>
  </ffsocket>
  <system>
    <initialize nbeads='1'>
      <file mode='pdb'> init_ipi.pdb </file>
      <velocities mode='thermal' units='kelvin'> 298.15 </velocities>
    </initialize>
    <forces>
      <force forcefield='dmff' ></force>
    </forces>
    <ensemble>
      <temperature units='kelvin'> 298.15 </temperature>
    </ensemble>
    <motion mode='dynamics'>
      <dynamics mode='nvt'>
        <thermostat mode='langevin'>
          <tau units='femtosecond'> 10 </tau>
        </thermostat>
        <timestep units='femtosecond'> 0.5 </timestep>
      </dynamics>
    </motion>
  </system>
</simulation>
